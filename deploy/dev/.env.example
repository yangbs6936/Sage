# Docker Compose deployment settings
SAGE_ROOT=../data/dev

# Sage runtime settings
SAGE_ENV=development
SAGE_TRACE_JAEGER_PUBLIC_URL=

# Sandbox settings
SAGE_SANDBOX_MODE=local
SAGE_SANDBOX_MOUNT_PATHS=
SAGE_REMOTE_PROVIDER=opensandbox
OPENSANDBOX_URL=
OPENSANDBOX_API_KEY=

# Auth settings
SAGE_BOOTSTRAP_ADMIN_USERNAME=admin
SAGE_BOOTSTRAP_ADMIN_PASSWORD=change_this_admin_password
SAGE_JWT_KEY=change_this_jwt_secret
SAGE_REFRESH_TOKEN_SECRET=change_this_refresh_secret
SAGE_SESSION_SECRET=change_this_session_secret
SAGE_SESSION_COOKIE_SECURE=false

# Email verification settings
SAGE_EML_ACCESS_KEY_ID=
SAGE_EML_ACCESS_KEY_SECRET=
SAGE_EML_SECURITY_TOKEN=
SAGE_EML_ACCOUNT_NAME=sage@mail.example.com
SAGE_EML_TEMPLATE_ID=

# Default LLM settings
SAGE_DEFAULT_LLM_API_KEY=

# MySQL settings
SAGE_DB_TYPE=mysql
SAGE_MYSQL_HOST=sage-mysql
SAGE_MYSQL_PORT=3306
SAGE_MYSQL_DATABASE=sage_dev
SAGE_MYSQL_USER=root
SAGE_MYSQL_PASSWORD=change_this_mysql_password

# Optional external Elasticsearch settings
SAGE_ELASTICSEARCH_URL=
SAGE_ELASTICSEARCH_USERNAME=elastic
SAGE_ELASTICSEARCH_PASSWORD=change_this_elasticsearch_password

# RustFS / S3 settings
SAGE_S3_ENDPOINT=sage-rustfs:9000
SAGE_S3_ACCESS_KEY=root
SAGE_S3_SECRET_KEY=change_this_s3_secret
SAGE_S3_SECURE=false
SAGE_S3_BUCKET_NAME=sage
SAGE_S3_PUBLIC_BASE_URL=

# Embedding settings
SAGE_EMBEDDING_API_KEY=
