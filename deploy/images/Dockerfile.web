# syntax=docker.m.daocloud.io/docker/dockerfile:1.8.1

# --- Build stage: use Node 22 to satisfy Vite requirements ---
FROM docker.m.daocloud.io/node:22-alpine AS builder
WORKDIR /app
ENV NODE_OPTIONS="--dns-result-order=ipv4first --max-old-space-size=4096" \
    npm_config_registry=https://registry.npmmirror.com \
    npm_config_fetch_retries=5 \
    npm_config_fetch_retry_maxtimeout=600000 \
    npm_config_fund=false \
    npm_config_audit=false \
    npm_config_progress=false

# Copy dependency manifests first so source edits do not invalidate npm install
COPY --link app/server/web/package.json app/server/web/package-lock.json ./

RUN --mount=type=cache,id=sage-web-npm-cache,target=/root/.npm,sharing=locked \
    npm ci --prefer-offline

# Copy the rest of the app after dependencies are installed to maximize cache reuse
COPY --link app/server/web/ .

ARG VITE_SAGE_GRAFANA_URL=http://127.0.0.1:30093
ENV VITE_SAGE_GRAFANA_URL=${VITE_SAGE_GRAFANA_URL}

RUN npm run build

# --- Runtime stage: serve static files with Nginx ---
FROM docker.m.daocloud.io/nginx:1.27-alpine

ARG NGINX_CONF=deploy/prod/nginx/nginx.conf
COPY --link ${NGINX_CONF} /etc/nginx/conf.d/default.conf

# Copy build output to Nginx html directory
COPY --link --from=builder /app/dist /usr/share/nginx/html

EXPOSE 80

# Simple healthcheck to ensure Nginx responds
HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 CMD wget -qO- http://127.0.0.1/sage/ || exit 1
