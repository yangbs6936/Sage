#!/usr/bin/env sh
set -eu

if ! command -v ruff >/dev/null 2>&1; then
  echo "ruff is required before commit. Install it with: python -m pip install 'ruff==0.15.14'" >&2
  exit 1
fi

echo "Running ruff format before commit..."
ruff format .

echo "Running ruff check before commit..."
ruff check . --fix

if ! git diff --quiet; then
  echo "Ruff changed files. Review and stage the formatting/lint fixes, then commit again." >&2
  exit 1
fi
