#!/usr/bin/env sh
set -eu

if ! command -v ruff >/dev/null 2>&1; then
  echo "ruff is required before merge commit. Install it with: python -m pip install 'ruff==0.15.14'" >&2
  exit 1
fi

echo "Running ruff format before merge commit..."
ruff format .

echo "Running ruff check before merge commit..."
ruff check . --fix

if ! git diff --quiet; then
  echo "Ruff changed files during merge validation. Review and stage the fixes before committing the merge." >&2
  exit 1
fi
